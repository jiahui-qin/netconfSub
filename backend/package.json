{
  "name": "netconf-tool",
  "version": "1.0.0",
  "description": "Netconf Device Management Tool",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node index.js",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd ../frontend && npm install && npm run build",
    "build:backend": "node ../build-scripts.js",
    "prepkg": "npm run build:backend",
    "pkg": "pkg . --targets node20-linux-x64,node20-macos-x64,node20-win-x64 --out-path ../dist",
    "pkg:win": "npm run prepkg && pkg . --targets node20-win-x64 --out-path ../dist",
    "pkg:linux": "npm run prepkg && pkg . --targets node20-linux-x64 --out-path ../dist",
    "pkg:mac": "npm run prepkg && pkg . --targets node20-macos-x64 --out-path ../dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["netconf", "network", "management"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bin": "index.js",
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "outputPath": "../dist",
    "targets": [
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-win-x64"
    ]
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "netconf-client": "^2.0.8",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
